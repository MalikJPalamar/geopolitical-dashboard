# Nginx configuration for centaurion.me/geopolitical-lens
# Place this in /etc/nginx/sites-available/centaurion.me

upstream geopolitical_lens_backend {
    server localhost:3001;
    keepalive 64;
}

server {
    listen 80;
    listen [::]:80;
    server_name centaurion.me www.centaurion.me;

    # Redirect HTTP to HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name centaurion.me www.centaurion.me;

    # SSL configuration (adjust paths as needed)
    ssl_certificate /etc/letsencrypt/live/centaurion.me/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/centaurion.me/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;

    # Logging
    access_log /var/log/nginx/geopolitical-lens.access.log;
    error_log /var/log/nginx/geopolitical-lens.error.log;

    # Geopolitical Lens Dashboard
    location /geopolitical-lens/ {
        proxy_pass http://geopolitical_lens_backend/;
        proxy_http_version 1.1;
        
        # WebSocket support (if needed in future)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        
        # Standard proxy headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        
        # Cache bypass
        proxy_cache_bypass $http_upgrade;
        
        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        
        # Buffer settings
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;
    }

    # Optional: Other locations for your domain
    location / {
        root /var/www/centaurion.me;
        index index.html index.htm;
        try_files $uri $uri/ =404;
    }
}
