# Copy this file to .env and fill in your Anthropic API key
# Never commit .env to git

ANTHROPIC_API_KEY=sk-ant-...

# Optional: change the server port (default 3001)
PORT=3001

# Optional: FRED API key for live Baltic Dry Index data
# Register free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
