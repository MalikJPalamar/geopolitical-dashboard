# Copy this file to .env and fill in your Anthropic API key
# Never commit .env to git

# Required: Anthropic API key for Claude access
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Server configuration
PORT=3001

# Environment (development or production)
NODE_ENV=production

# Base path for deployment (e.g., /geopolitical-lens for centaurion.me/geopolitical-lens)
BASE_PATH=/geopolitical-lens
