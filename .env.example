# Copy to .env — never commit .env to git

ANTHROPIC_API_KEY=sk-ant-...

# Optional — change server port (default 3001)
PORT=3001

# Optional — FRED API key for live Baltic Dry Index
# Free registration: https://fred.stlouisfed.org/docs/api/api_key.html
# Without this key, /api/bdi returns baseline fallback (2710)
FRED_API_KEY=
